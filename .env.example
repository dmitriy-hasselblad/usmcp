# Public application URL used for authentication redirects.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Supabase project settings - copy this file to .env.local and add your values.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-key

# Enable only after supabase/schema.sql has been applied successfully.
NEXT_PUBLIC_AUTH_ENABLED=false
